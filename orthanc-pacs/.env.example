# ============================================================
# Orthanc PACS & MWL Sync — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# All settings can be changed here without entering any container.
# ============================================================

# --- Orthanc Internal Database (MariaDB) ---
MARIADB_ROOT_PASSWORD=
MARIADB_DATABASE=orthanc_db
MARIADB_USER=
MARIADB_PASSWORD=

# --- SIMRS Khanza Database (External) ---
SIMRS_DB_HOST=
SIMRS_DB_PORT=3306
SIMRS_DB_USER=
SIMRS_DB_PASS=
SIMRS_DB_NAME=sik

# --- Orthanc PACS Server ---
ORTHANC_AET=ORTHANC
ORTHANC_HTTP_PORT=8042
ORTHANC_DICOM_PORT=4242
ORTHANC_WEB_USER=admin
ORTHANC_WEB_PASS=changeme

# --- MWL Dashboard ---
MWL_DASHBOARD_PORT=8081
MWL_WEB_USER=admin
MWL_WEB_PASS=changeme
MWL_SYNC_INTERVAL=10
MWL_DASHBOARD_REFRESH_SEC=300
MWL_STALE_DAYS=2
MWL_INSTITUTION_NAME=
MWL_LOOKBACK_DAYS=2

# --- DICOM UID ---
# Use your organization's OID root, or leave as 2.25 (UUID-derived, standard per DICOM PS3.5 Annex B)
DICOM_UID_ROOT=2.25

# --- Samba Network Share (for non-WL CR Import) ---
SHARE_NAME=DICOM-SHARE
SHARE_USER=orthanc
SHARE_PASS=orthanc
SHARE_UID=1000
SHARE_GID=1000

# --- General ---
TZ=Asia/Jakarta
