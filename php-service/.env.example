# ─── Database Connection ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sik
DB_USER=root
DB_PASS=

# ─── BPJS Aplicare API ─────────────────────────────────────────────────────
# Cons-ID used for HMAC signature generation
APLICARE_CONS_ID=
# Secret key used for HMAC-SHA256 signature
APLICARE_SECRET_KEY=
# User key (not used in headers currently, reserved for future BPJS updates)
APLICARE_USER_KEY=
# Cons-ID sent in X-Cons-ID header (may differ from signature cons-id)
APLICARE_HEADER_CONS_ID=

# ─── API Endpoint ──────────────────────────────────────────────────────────
# Aplicare base URL (no trailing slash)
# Development : https://dvlp.bpjs-kesehatan.go.id:8888/aplicaresws
# Production  : https://new-api.bpjs-kesehatan.go.id/aplicaresws
APLICARE_BASE_URL=https://dvlp.bpjs-kesehatan.go.id:8888/aplicaresws

# ─── Facility ──────────────────────────────────────────────────────────────
# Kode PPK (Provider). If empty, will be fetched from `setting` table.
KODE_PPK=

# ─── Logging ───────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Root log directory (relative to script or absolute path)
# Each service creates its own subfolder: logs/aplicare/, logs/icare/, logs/mobilejkn/
LOG_DIR=logs
# Maximum age (in days) for log files and cache files. Files older than this
# are automatically deleted on each run. Applies to all services.
# Set to 0 to disable auto-cleanup.
LOG_RETENTION_DAYS=30

# ─── Timezone ──────────────────────────────────────────────────────────────
TIMEZONE=Asia/Jakarta

# ─── BPJS iCare API ────────────────────────────────────────────────────────
# Cons-ID for iCare HMAC signature generation
ICARE_CONS_ID=
# Secret key for iCare HMAC-SHA256 signature
ICARE_SECRET_KEY=
# User key for iCare API header
ICARE_USER_KEY=
# iCare wsihs base URL (no trailing slash)
# Production: https://apijkn.bpjs-kesehatan.go.id/wsihs
ICARE_BASE_URL=https://apijkn.bpjs-kesehatan.go.id/wsihs

# ─── BPJS Mobile JKN Antrean API ──────────────────────────────────────────
# Leave CONS_ID/SECRET_KEY/USER_KEY empty to auto-use APLICARE_* credentials.
# Only set these if your Mobile JKN credentials differ from Aplicare.
MOBILEJKN_CONS_ID=
MOBILEJKN_SECRET_KEY=
MOBILEJKN_USER_KEY=
# Mobile JKN antrean base URL (no trailing slash)
# Development: https://apijkn-dev.bpjs-kesehatan.go.id/antreanrs_dev
# Production:  https://apijkn.bpjs-kesehatan.go.id/antreanrs
MOBILEJKN_BASE_URL=
# Concurrent HTTP batch size (parallel curl_multi requests)
MOBILEJKN_BATCH_SIZE=4
# Date range lookback in days for unsent bookings
MOBILEJKN_LOOKBACK_DAYS=6
# Include Non-JKN (non-BPJS) patients in queue sync (true/false)
MOBILEJKN_INCLUDE_NON_JKN=true

# ─── Satu Sehat API ────────────────────────────────────────────────────────
SATUSEHAT_ORG_ID=
SATUSEHAT_CLIENT_ID=
SATUSEHAT_SECRET_KEY=
SATUSEHAT_AUTH_URL=https://api-satusehat-dev.dto.kemkes.go.id/oauth2/v1
SATUSEHAT_BASE_URL=https://api-satusehat-dev.dto.kemkes.go.id/fhir-r4/v1
# Token Cache TTL (seconds)
SATUSEHAT_TOKEN_TIMEOUT=3000
# Delay between requests to avoid 429 Too Many Requests (milliseconds)
SATUSEHAT_DELAY_MS=500
# Date range configuration:
# If SATUSEHAT_LOOKBACK_DAYS > 0, it calculates the range dynamically (exclusive of today).
# Example: If today is May 21 and LOOKBACK_DAYS=2, it queries May 19 to May 20.
SATUSEHAT_LOOKBACK_DAYS=0
# If SATUSEHAT_LOOKBACK_DAYS is 0 or empty, it uses SATUSEHAT_DATE_FROM and SATUSEHAT_DATE_TO.
# Format: YYYY-MM-DD
SATUSEHAT_DATE_FROM=
SATUSEHAT_DATE_TO=
# Batch processing: number of records to fetch per batch (default: 500).
# Lower = less memory, more queries. Higher = faster, more memory.
SATUSEHAT_BATCH_SIZE=500
# Memory limit for sync processes (default: 512M).
SATUSEHAT_MEMORY_LIMIT=512M

# ─── DICOM Router Webhook Authentication ────────────────────────────────────
WEBHOOK_USER=user_webhook_rs
WEBHOOK_PASSWORD=password_webhook_rs

# ─── PACS / Orthanc & DICOM Converter ────────────────────────────────────────
ORTHANC_URL=http://localhost
ORTHANC_PORT=8042
ORTHANC_USER=admin
ORTHANC_PASS=password
DICOM_CONVERTER_URL=http://localhost
DICOM_CONVERTER_PORT=8080
DICOM_ROUTER_AE=DCMROUTER
SIMRS_WEBAPPS_URL=http://localhost/webapps


